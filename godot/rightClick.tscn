[gd_scene format=3 uid="uid://qsmjm2xwsxsv"]

[sub_resource type="GDScript" id="GDScript_7b2kf"]
script/source = "extends CanvasLayer

@export 
var wh 			: window_handler
var temp_pos 	: Vector2i

@export var edit_widow: Window

func _ready() -> void:
	wh.window_interactable_change.connect(on_window_interactable_change)

func on_window_interactable_change(active : bool) -> void:
	if not visible:
		return
	close()

func _on_button_reset_pressed() -> void:
	wh.i = 0
	wh.label.text = str(wh.i)
	close()
	
func _on_button_back_pressed() -> void:
	close()

func _on_button_quit_pressed() -> void:
	Config.set_window_pos(temp_pos)
	wh.quit()

func _on_manage_pressed() -> void:
	if  edit_widow.visible:
		edit_widow.hide()
	else:
		edit_widow.show()
	
func close():
	visible = false
	wh.label.visible = true

func _on_visibility_changed() -> void:
	if visible:
		temp_pos = get_window().position
		wh.clamp_window_to_screen()
	else:
		get_window().position = temp_pos
"

